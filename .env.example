# Dolcera Environment Variables
# Copy this file to .env and fill in your values

# ═══ SUPABASE CONFIGURATION ═══
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ═══ OPTIONAL ANALYTICS ═══
# Google Analytics
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ═══ PRODUCTION DOMAIN ═══
PRODUCTION_URL=https://dolcera.me

# ═══ FIREBASE (for image storage) ═══
# Optional - if using Firebase for media uploads
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# ═══ NOTES ═══
# For Cloudflare Pages deployment:
# Add these variables in Cloudflare Dashboard > Pages > Settings > Environment variables
# 
# For local development:
# The HTML file will fall back to hardcoded values if env vars are not found
